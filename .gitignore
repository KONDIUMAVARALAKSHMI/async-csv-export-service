# pyenv
#   For a library or binary, you wish to ignore these files by default.
#   For a development environment, you might want to check them in.
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not check in Pipfile.lock into version control.
#   However, in case of collaboration, if you want to share the exact same environment, you should check in Pipfile.lock.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to check poetry.lock into control.
#   With a library, you should add poetry.lock to your .gitignore.
#   For an application, you should check it in.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to check pdm.lock into control.
#pdm.lock
#   pdm build auxiliary directory
.pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

